# CostHive bundled-tool pinned versions — the single source of truth (addendum §8).
#
# Consumed by:
#   - Dockerfile           (build ARGs; installs each tool at these versions)
#   - scripts/verify-tools.sh (CI tool-integrity job asserts installed == pinned)
#
# Bumping any version here is a savings-impacting change (findings can change) —
# note it in CHANGELOG.md. Dependabot opens PRs when new versions ship.
STEAMPIPE_VERSION=2.4.4
CUSTODIAN_VERSION=0.9.51
INFRACOST_VERSION=0.10.44
CLOUDQUERY_VERSION=6.38.0
KOMISER_VERSION=3.1.22
OPENCOST_VERSION=1.120.4
